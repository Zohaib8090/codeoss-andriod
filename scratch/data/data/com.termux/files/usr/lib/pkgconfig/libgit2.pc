prefix="/data/data/com.termux/files/usr"
libdir="/data/data/com.termux/files/usr/lib"
includedir="/data/data/com.termux/files/usr/include"

Name: libgit2
Description: The git library, take 2
Version: 1.9.2
Libs: -L${libdir} -lgit2
Libs.private: -L/data/data/com.termux/files/usr/lib -lssh2 -lrt -lpthread
Requires.private: openssl libpcre2-8 zlib
Cflags: -I${includedir} 
